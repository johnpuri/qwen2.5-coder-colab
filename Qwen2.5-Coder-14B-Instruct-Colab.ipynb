  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Qwen2.5-Coder-14B-Instruct on Google Colab (Free GPU)",
        "This notebook loads Qwen2.5-Coder-14B-Instruct with vLLM and exposes it as an OpenAI-compatible API endpoint for OpenHands."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Setup Environment"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "!pip install -q torch transformers accelerate sentencepiece vllm fastapi uvicorn python-multipart pyngrok"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Check GPU"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "import torch\nprint(f'GPU available: {torch.cuda.is_available()}')\nprint(f'GPU: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else "None"}')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Load Model with vLLM"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "from vllm import LLM, SamplingParams\n\nmodel_name = "Qwen/Qwen2.5-Coder-14B-Instruct"\nllm = LLM(model=model_name, trust_remote_code=True, tensor_parallel_size=1)"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Expose as FastAPI Endpoint"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "from fastapi import FastAPI, Request\nfrom fastapi.responses import JSONResponse\nimport uvicorn\nimport json\n\napp = FastAPI()\n\n@app.post("/v1/chat/completions")\nasync def chat_completions(request: Request):\n    body = await request.json()\n    prompts = [body["messages"][-1]["content"]]  # Extract latest user message\n    sampling_params = SamplingParams(temperature=0.7, max_tokens=1024)\n    outputs = llm.generate(prompts, sampling_params)\n    response = {\n        "choices": [{\n            "message": {"role": "assistant", "content": outputs[0].outputs[0].text},
            "finish_reason": "stop"
        }]
    }\n    return JSONResponse(content=response)\n\nif __name__ == "__main__":\n    uvicorn.run(app, host="0.0.0.0", port=8000)"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5. (Optional) Expose via Ngrok"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "!ngrok authtoken YOUR_NGROK_AUTH_TOKEN  # Replace with your ngrok token\nfrom pyngrok import ngrok\n\npublic_url = ngrok.connect(8000).public_url\nprint(f'Public endpoint: {public_url}/v1/chat/completions')"
      ],
      "outputs": []
    }
